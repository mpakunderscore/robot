Servo servo[8];

int firstAngle = 20;
int secondAngle = 80;



void setLegs(int percent) {
  if (percent < 100 && percent >= 0) {
//    servo[0].write(firstAngle);
    servo[1].write(percent * 90);
//    servo[2].write(180 - firstAngle);
    servo[3].write(180 - percent * 90 /100);

//    servo[4].write(50);
    servo[5].write(180 - percent * 90 /100);
//    servo[6].write(180 - 50);
    servo[7].write(percent * 90);
  }
}

void stand() {
  servo[0].write(firstAngle);
  servo[1].write(secondAngle);
  servo[2].write(180 - firstAngle);
  servo[3].write(180 - secondAngle);

  servo[4].write(50);
  servo[5].write(90);
  servo[6].write(180 - 50);
  servo[7].write(180 - 90);
}

void sit() {
  servo[0].write(0);
  servo[1].write(30);
  servo[2].write(180);
  servo[3].write(150);

  servo[4].write(90);
  servo[5].write(150);
  servo[6].write(90);
  servo[7].write(30);
}

void initServo() {
  servo[0].attach(4);
  servo[1].attach(5);
  servo[2].attach(6);
  servo[3].attach(7);

  servo[4].attach(0);
  servo[5].attach(1);
  servo[6].attach(2);
  servo[7].attach(3);

  Serial.begin(9600);
  Serial.setTimeout(0);
}

void setup() {

  initServo();

  stand();

