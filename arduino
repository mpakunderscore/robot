void stand() {
  servo[0].write(firstAngle);
  servo[1].write(secondAngle);
  servo[2].write(180 - firstAngle);
  servo[3].write(180 - secondAngle);

  servo[4].write(70);
  servo[5].write(110);
  servo[6].write(180 - 70);
  servo[7].write(180 - 110);
}

void sit() {
  servo[0].write(0);
  servo[1].write(30);
  servo[2].write(180);
  servo[3].write(150);

  servo[4].write(90);
  servo[5].write(150);
  servo[6].write(90);
  servo[7].write(30);
}

